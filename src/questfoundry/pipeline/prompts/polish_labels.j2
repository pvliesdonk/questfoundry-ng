{% for d in dests %}
- to group {{ d.index }}{% if d.is_ending %} [ENDING]{% endif %}{% if d.requires %} (only shown to a player who has {{ d.requires | join(", ") }}){% endif %}{% if d.grants %} (taking it locks in {{ d.grants | join(", ") }}){% endif %}: {{ d.summary }}{% if d.premise %}
  ENTERS A RENDERING — this choice steps into a world where {{ d.premise }}; the label may name that world so the reader chooses between the offered backdrops.{% endif %}{% if d.siblings %}
